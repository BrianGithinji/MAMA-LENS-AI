# ============================================================
# MAMA-LENS AI — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Application ---
APP_ENV=development
APP_NAME=MAMA-LENS AI
APP_VERSION=1.0.0
SECRET_KEY=your-secret-key-min-32-chars-here
DEBUG=false

# --- Database ---
DATABASE_URL=postgresql://mamalens:password@localhost:5432/mamalens_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password

# --- JWT Authentication ---
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# --- ElevenLabs (Text-to-Speech) ---
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID_EN=your-english-voice-id
ELEVENLABS_VOICE_ID_SW=your-swahili-voice-id
ELEVENLABS_VOICE_ID_FR=your-french-voice-id

# --- Whisper (Speech-to-Text) ---
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=auto

# --- LiveKit (Telemedicine) ---
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-livekit-server.com

# --- WhatsApp Business API ---
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# --- Africa's Talking (SMS/USSD) ---
AFRICASTALKING_API_KEY=your-africastalking-api-key
AFRICASTALKING_USERNAME=your-username
AFRICASTALKING_SENDER_ID=MAMALENS
AFRICASTALKING_USSD_CODE=*384*1234#

# --- Twilio (SMS fallback) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# --- AWS ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=af-south-1
AWS_S3_BUCKET=mamalens-media
AWS_S3_BUCKET_DOCUMENTS=mamalens-documents

# --- Google Maps / GIS ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@mamalens.ai
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=MAMA-LENS AI <noreply@mamalens.ai>

# --- Push Notifications ---
FCM_SERVER_KEY=your-firebase-server-key
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id

# --- Encryption ---
ENCRYPTION_KEY=your-32-byte-encryption-key-here
FIELD_ENCRYPTION_KEY=your-field-level-encryption-key

# --- Monitoring ---
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
PROMETHEUS_PORT=9090

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,https://app.mamalens.ai
ALLOWED_HOSTS=localhost,app.mamalens.ai,api.mamalens.ai

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# --- Feature Flags ---
ENABLE_TELEMEDICINE=true
ENABLE_WEARABLES=true
ENABLE_AVATAR=true
ENABLE_WHATSAPP=true
ENABLE_SMS_USSD=true
ENABLE_OFFLINE_MODE=true
