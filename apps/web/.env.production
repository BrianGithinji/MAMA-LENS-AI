# ============================================================
# MAMA-LENS AI — Frontend Environment Variables (Production)
# apps/web/.env.production
# Used by Netlify during build — set VITE_API_URL after
# deploying the backend on Render.
# ============================================================

# Backend API URL — your Render service URL
VITE_API_URL=https://mama-lens-ai.onrender.com/api/v1

# App info
VITE_APP_NAME=MAMA-LENS AI
VITE_APP_VERSION=1.0.0

# Google Maps (for facility map display)
VITE_GOOGLE_MAPS_API_KEY=

# LiveKit (telemedicine room — client side)
VITE_LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# Feature flags
VITE_ENABLE_TELEMEDICINE=true
VITE_ENABLE_AVATAR=true
VITE_ENABLE_WHATSAPP=true
