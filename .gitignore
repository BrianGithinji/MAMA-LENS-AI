# ─── Secrets — NEVER commit these ───────────────────────────
backend/api/.env
apps/web/.env
.env.local
.env.*.local

# .env.production is safe to commit (no secrets, just the Render URL)
# .env.example is safe to commit (template only)

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
.venv311/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# ─── Database files ──────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ─── Node / Frontend ─────────────────────────────────────────
node_modules/
apps/web/dist/
apps/web/.vite/
*.log
npm-debug.log*

# ─── AI Models (large binary files) ─────────────────────────
ai/*/models/*.joblib
ai/*/models/*.pkl
ai/*/models/*.h5

# ─── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ─────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
